	option s_vless_user_alter_id '0'
	option s_trojan_port '65249'
	option s_trojan_user_security 'chacha20-poly1305'
	option s_trojan_user_encryption 'none'
	option s_trojan_user_alter_id '0'
	option s_socks_port '65251'
	option s_socks_user_security 'chacha20-poly1305'
	option s_socks_user_encryption 'none'
	option s_socks_user_alter_id '0'
	option ss_network 'tcp'
	option ss_security 'tls'
	option ss_tls_allow_insecure '1'
	option ss_tls_disable_system_root '1'
	option ss_tls_cert_usage 'verify'
	option ss_tls_cert_file '/etc/luci-uploads/client.crt'
	option ss_tls_key_file '/etc/luci-uploads/client.key'
	option s_shadowsocks_port '65252'
	option mux_concurrency '8'
	option ss_sockopt_mptcp '1'
	option s_vless_reality_port '443'
	option s_vless_reality_flow 'xtls-rprx-vision'
