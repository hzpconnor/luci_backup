config inbound 'omr'
	option tag 'omr'
	option listen '0.0.0.0'
	option port '1100'
	option protocol 'dokodemo-door'
	list s_dokodemo_door_network 'tcp'
	list s_dokodemo_door_network 'udp'
	option ss_sockopt_tproxy 'redirect'
	option ss_sockopt_tcp_fast_open '1'
	option ss_sockopt_mptcp '1'
	option s_dokodemo_door_follow_redirect '1'

config inbound 'omr6'
	option tag 'omr6'
	option listen '::'
	option port '1101'
	option protocol 'dokodemo-door'
	list s_dokodemo_door_network 'tcp'
	list s_dokodemo_door_network 'udp'
	option ss_sockopt_tproxy 'tproxy'
	option ss_sockopt_tcp_fast_open '1'
	option s_dokodemo_door_follow_redirect '1'

config inbound 'omrtest'
	option port '1111'
	option protocol 'socks'
	option listen '127.0.0.1'
	option s_socks_auth 'noauth'
	option s_socks_udp '1'
	option s_socks_ip '127.0.0.1'
	option s_socks_userlevel '0'

config reverse 'main_reverse'
	option enabled '1'
	option bridges 'omrbridge|omr.lan'

config outbound 'omrexit'
	option protocol 'freedom'
	option tag 'out'

config routing_rule 'omrrouting'
	option type 'field'
	option inbound_tag 'omrbridge'
	option outbound_tag 'omrout_tunnel'
	option domain 'full:omr.lan'

config routing_rule 'omrroutingo'
	option type 'field'
	option inbound_tag 'omrbridge'
	option outbound_tag 'out'

config routing 'main_routing'
	option enabled '1'
	list rules 'omrrouting'
	list rules 'omrroutingo'

