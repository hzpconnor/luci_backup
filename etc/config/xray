
config xray 'main'
	option xray_file '/usr/bin/xray'
	option mem_percentage '0'
	option loglevel 'error'
	option access_log '/dev/null'
	option error_log '/dev/null'
	option enabled '0'
	list outbounds 'omrout'
	list outbounds 'omrexit'
	list inbounds 'omr'
	list inbounds 'omrtest'
	list inbounds 'omr6'

config dns 'main_dns'
	option hosts 'example.com|127.0.0.1'
	option enabled '0'

config policy 'main_policy'
	option enabled '1'
	option levels 'policy_level_0'

config policy_level 'policy_level_0'
	option level '0'
	option handshake '4'
	option conn_idle '1200'
	option uplink_only '0'
	option downlink_only '0'
	option buffer_size '512'

config transparent_proxy 'main_transparent_proxy'
	option proxy_mode 'default'
	option apnic_delegated_mirror 'apnic'
	option gfwlist_mirror 'github'
	option redirect_udp '0'
	option redirect_port '1100'

config outbound 'omrout'
	option tag 'omrout_tunnel'
	option protocol 'vless'
	option s_vmess_port '65250'
	option s_vmess_user_security 'chacha20-poly1305'
