
config core 'main'
	option lang 'auto'
	option mediaurlbase '/luci-static/openmptcprouter'
	option resourcebase '/luci-static/resources'
	option ubuspath '/ubus/'

config extern 'flash_keep'
	option uci '/etc/config/'
	option dropbear '/etc/dropbear/'
	option openvpn '/etc/openvpn/'
	option passwd '/etc/passwd'
	option opkg '/etc/opkg.conf'
	option firewall '/etc/firewall.user'
	option uploads '/lib/uci/upload/'

config internal 'languages'
	option ar 'العربية (Arabic)'
	option bg 'български (Bulgarian)'
	option bn 'বাংলা (Bengali)'
	option ca 'Català (Catalan)'
	option cs 'Čeština (Czech)'
	option de 'Deutsch (German)'
	option el 'Ελληνικά (Greek)'
	option es 'Español (Spanish)'
	option fi 'Suomi (Finnish)'
	option fr 'Français (French)'
	option he 'עִבְרִית (Hebrew)'
	option hi 'हिंदी (Hindi)'
	option hu 'Magyar (Hungarian)'
	option it 'Italiano (Italian)'
	option ja '日本語 (Japanese)'
	option ko '한국어 (Korean)'
	option mr 'Marāṭhī (Marathi)'
	option ms 'Bahasa Melayu (Malay)'
	option no 'Norsk (Norwegian)'
	option pl 'Polski (Polish)'
	option pt 'Português (Portuguese)'
	option pt_br 'Português do Brasil (Brazilian Portuguese)'
	option ro 'Română (Romanian)'
	option ru 'Русский (Russian)'
	option sk 'Slovenčina (Slovak)'
	option sv 'Svenska (Swedish)'
	option tr 'Türkçe (Turkish)'
	option uk 'Українська (Ukrainian)'
	option vi 'Tiếng Việt (Vietnamese)'
	option zh_cn '简体中文 (Chinese Simplified)'
	option zh_tw '繁體中文 (Chinese Traditional)'

config internal 'sauth'
	option sessionpath '/tmp/luci-sessions'
	option sessiontime '3600'

config internal 'ccache'
	option enable '1'

config internal 'themes'
	option Alpha '/luci-static/alpha'
	option Argon '/luci-static/argon'
	option Bootstrap '/luci-static/bootstrap'
	option BootstrapDark '/luci-static/bootstrap-dark'
	option BootstrapLight '/luci-static/bootstrap-light'
	option Design '/luci-static/design'
	option Material '/luci-static/material'
	option OpenWrt2020 '/luci-static/openwrt2020'
	option OpenMPTCProuter '/luci-static/openmptcprouter'

config internal 'apply'
	option rollback '90'
	option holdoff '4'
	option timeout '20'
	option display '1.5'

config internal 'diag'
	option ping 'www.openmptcprouter.com'
	option dns 'www.openmptcprouter.com'
	option route 'www.openmptcprouter.com'
	option iperf3 'ping-ams1.online.net'
	option getip 'ip.openmptcprouter.com'

