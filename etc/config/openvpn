
config openvpn 'custom_config'
	option enabled '0'
	option config '/etc/openvpn/my-vpn.conf'

config openvpn 'sample_server'
	option enabled '0'
	option port '1194'
	option proto 'udp'
	option dev 'tun'
	option ca '/etc/openvpn/ca.crt'
	option cert '/etc/openvpn/server.crt'
	option key '/etc/openvpn/server.key'
	option dh '/etc/openvpn/dh2048.pem'
	option server '10.8.0.0 255.255.255.0'
	option ifconfig_pool_persist '/tmp/ipp.txt'
	option keepalive '10 120'
	option persist_key '1'
	option persist_tun '1'
	option user 'nobody'
	option status '/tmp/openvpn-status.log'
	option verb '3'

config openvpn 'sample_client'
	option enabled '0'
	option client '1'
	option dev 'tun'
	option proto 'udp'
	list remote 'my_server_1 1194'
	option resolv_retry 'infinite'
	option nobind '1'
	option persist_key '1'
	option persist_tun '1'
	option user 'nobody'
	option ca '/etc/openvpn/ca.crt'
	option cert '/etc/openvpn/client.crt'
	option key '/etc/openvpn/client.key'
	option verb '3'

config openvpn 'omr'
	option dev 'tun0'
	option port '65301'
	option cipher 'CHACHA20-POLY1305'
	option proto 'tcp-client'
	option auth_nocache '1'
	option client '1'
	option tls_client '1'
	option reneg_sec '0'
	option allow_recursive_routing '1'
	option sndbuf '0'
	option rcvbuf '0'
	option route_delay '5'
	option disable_dco '1'
	option ping_restart '60'
	option tun_mtu '1420'
	option key '/etc/luci-uploads/client.key'
	option cert '/etc/luci-uploads/client.crt'
	option ca '/etc/luci-uploads/ca.crt'
	list remote '120.25.222.197'

config openvpn 'omr2'
	option dev 'tun1'
	option port '65301'
	option cipher 'CHACHA20-POLY1305'
	option proto 'tcp-client'
	option auth_nocache '1'
	option client '1'
	option tls_client '1'
	option reneg_sec '0'
	option allow_recursive_routing '1'
	option sndbuf '0'
	option rcvbuf '0'
	option route_delay '5'
	option disable_dco '1'
	option ping_restart '60'
	option tun_mtu '1420'
	option key '/etc/luci-uploads/client.key'
	option cert '/etc/luci-uploads/client.crt'
	option ca '/etc/luci-uploads/ca.crt'
	list remote '120.25.222.197'

